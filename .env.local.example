NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WeChat OAuth
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# AI Services
OPENAI_API_KEY=your-openai-api-key
GOOGLE_VISION_API_KEY=your-google-vision-api-key

# Stripe (optional if you only use WeChat Pay / Alipay)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# WeChat Pay
WECHAT_PAY_APP_ID=your-wechat-pay-app-id
WECHAT_PAY_MCH_ID=your-wechat-pay-merchant-id
WECHAT_PAY_NOTIFY_URL=http://localhost:3000/api/webhooks?provider=wechat
WECHAT_PAY_API_KEY=your-wechat-pay-api-key

# Alipay
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_NOTIFY_URL=http://localhost:3000/api/webhooks?provider=alipay
ALIPAY_PUBLIC_KEY=your-alipay-public-key

# Push Notifications
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# Scheduled jobs
CRON_SECRET=your-cron-secret
